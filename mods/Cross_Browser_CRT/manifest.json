{
    "manifest_version": 3,
    "name": "CRT Shader Mod",
    "description": "A cross-browser CRT shader effect mod. Applies retro CRT visual effects and keyboard sounds to any web page.",
    "version": "1.0.0",
    "icons": {
        "16": "icons/icon_16.png",
        "48": "icons/icon_48.png",
        "128": "icons/icon_128.png"
    },
    "permissions": [
        "storage",
        "activeTab"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon_16.png",
            "48": "icons/icon_48.png",
            "128": "icons/icon_128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["css/mod-base.css"],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["shaders/*", "sounds/*", "css/*"],
            "matches": ["<all_urls>"]
        }
    ]
}
